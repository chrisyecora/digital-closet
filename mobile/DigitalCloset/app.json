{
  "expo": {
    "name": "DigitalCloset",
    "slug": "DigitalCloset",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "digitalcloset",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.christopheryecora.DigitalCloset",
      "infoPlist": {
        "NSCameraUsageDescription": "Digital Closet needs access to your camera to identify and track your clothing items.",
        "NSPhotoLibraryUsageDescription": "Digital Closet needs access to your photo library to upload clothing items."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": ["android.permission.CAMERA"],
      "package": "com.christopheryecora.DigitalCloset"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-image-picker",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "contenFit": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store",
      "expo-web-browser",
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "Digital Closet needs access to your camera to identify and track your clothing items.",
          "enableCodeScanner": true
        }
      ],
      "./plugins/withDisableUserScriptSandboxing.js"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
